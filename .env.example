# Dataminr (current API)
DATAMINR_CLIENT_ID=
DATAMINR_CLIENT_SECRET=
# DATAMINR_AUTH_URL=https://api.dataminr.com/auth/v1/token
# DATAMINR_ALERTS_URL=https://api.dataminr.com/firstalert/v1/alerts
# DATAMINR_TOKEN_TTL=12600

# Dataminr Legacy API (fallback)
# Set DATAMINR_USE_LEGACY=true to force legacy API
# DATAMINR_USE_LEGACY=false
# DATAMINR_LEGACY_BASE_URL=https://firstalert-api.dataminr.com
# DATAMINR_LEGACY_USER_ID=
# DATAMINR_LEGACY_PASSWORD=
# DATAMINR_ALERT_VERSION=19

# GDACS (public API — no auth required)
# GDACS_BASE_URL=https://www.gdacs.org/gdacsapi
GDACS_COUNTRIES=Sudan,South Sudan,Ethiopia
GDACS_POLL_INTERVAL_MINUTES=30
GDACS_SOURCE_NAME=gdacs

# ACLED (Armed Conflict Location & Event Data Project)
# Get credentials at https://acleddata.com/register/
ACLED_USERNAME=
ACLED_PASSWORD=
# ACLED_BASE_URL=https://acleddata.com
ACLED_COUNTRIES=Sudan
ACLED_POLL_INTERVAL_MINUTES=60
ACLED_SOURCE_NAME=acled

# Redis
REDIS_URL=redis://localhost:6379/0

# CLEAR API
CLEAR_API_URL=http://localhost:4000/graphql
CLEAR_API_KEY=sk_live_...

# Claude (Anthropic)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0

# Pipeline settings
POLL_INTERVAL_SECONDS=15
INITIAL_LOOKBACK_DAYS=7
RELEVANCE_THRESHOLD=0.5
DEDUP_TTL_HOURS=48
DATAMINR_SOURCE_NAME=dataminr
MAX_PAGES_PER_POLL=50

# API server (FastAPI for receiving manual signals from clear-api)
API_PORT=8000
# API_SHARED_SECRET=
